# ═══════════════════════════════════════════════════════════
# MEDICOPLACE — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ═══════════════════════════════════════════════════════════

# ─── Required: Authentication ───
# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=

# Secret used for CSRF token signing. Generate with: openssl rand -base64 32
CSRF_SECRET=

# Secret used for password reset tokens. Generate with: openssl rand -base64 32
RESET_TOKEN_SECRET=

# ─── Required: Database (Supabase) ───
# Get these from your Supabase project → Settings → API
# Server-side Supabase URL (Vercel production env)
SUPABASE_URL=
# Client/server public Supabase URL (same value as SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (client-side Supabase use when needed)
SUPABASE_ANON_KEY=
# Service role key used by backend API routes
SUPABASE_SERVICE_ROLE_KEY=
# Optional direct Postgres URL (useful for SQL tooling/migrations)
DATABASE_URL=

# ─── Optional: Payments (MonCash) ───
# Get these from Digicel MonCash merchant portal
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
# Set to "production" for live payments, "sandbox" for testing
MONCASH_MODE=sandbox
# Dedicated secret for payment callback URL signatures. Generate with: openssl rand -base64 32
MONCASH_CALLBACK_SECRET=

# ─── Optional: Application URL ───
# Used for payment callback URLs and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional: Email Service ───
# Required for password reset emails. Configure your email provider.
# RESEND_API_KEY=
# EMAIL_FROM=noreply@medicoplace.ht
